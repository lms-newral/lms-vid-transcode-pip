NODE_ENV=development

# Queue used by lms-backend confirmVideoUploadV2
QUEUE_NAME=video-transcoding-v2
JOB_NAME=transcode-abr
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TLS=false

# Keep concurrency low. One job can consume CPU, disk and network heavily.
WORKER_CONCURRENCY=1
WORKER_LOCK_DURATION_MS=7200000
WORKER_LOCK_RENEW_TIME_MS=60000

# ACE Cloud / S3-compatible storage.
# AWS_* fallbacks are also supported, but prefer ACE_* for this worker.
ACE_S3_ENDPOINT=https://your-ace-s3-endpoint
ACE_S3_REGION=us-east-1
ACE_S3_BUCKET=your-bucket
ACE_S3_ACCESS_KEY_ID=your-access-key
ACE_S3_SECRET_ACCESS_KEY=your-secret-key
ACE_S3_FORCE_PATH_STYLE=true
ACE_S3_STORAGE_CLASS=STANDARD

# Backend callback. INTERNAL_VIDEO_SECRET must match lms-backend-main.
BACKEND_URL=http://localhost:3000
INTERNAL_VIDEO_SECRET=change-me

# DRM keys are dynamic and must come from the backend queue payload.
# Do not configure static DRM keys in worker env.

# Processing
WORK_DIR=/tmp/lms-vid-transcode-pip
MIN_FREE_DISK_BYTES=15000000000
SEGMENT_DURATION_SECONDS=2
FFMPEG_THREADS=6
X264_PRESET=veryfast
CLEANUP_WORK_DIR=true
